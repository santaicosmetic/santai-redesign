    "faq": {
      "type": "home-faq",
      "settings": {
        "eyebrow": "Common questions",
        "heading_pre": "You asked, ",
        "heading_italic": "we answered.",
        "full_faq_url": "/pages/faq"
      },
      "blocks": {
        "q1": { "type": "qa", "settings": { "question": "How do I choose the right lashes?",      "answer": "<p>Take our 60-second Lash Match quiz — pick your eye shape, the look you want, and how often you'll wear them. We'll match you to one of 8 styles. If you'd rather browse, start with Inbox (first-timer friendly) or Pitch (our bestseller).</p>" } },
        "q2": { "type": "qa", "settings": { "question": "Are they hard to wear for first-timers?", "answer": "<p>Genuinely easier than mascara. The first time takes about 5 minutes — after that, 30 seconds. The magnets do the alignment work; you just hold the band near your lash line and let it find its place.</p>" } },
        "q3": { "type": "qa", "settings": { "question": "Will they damage my natural lashes?",     "answer": "<p>No. Our lashes are magnet-only — no glue, no pulling, no tugging on your real lashes. Removal is a clean lift, not a pull.</p>" } },
        "q4": { "type": "qa", "settings": { "question": "How long do they last?",                   "answer": "<p>Up to 30 wears per pair when cared for properly. With our magnet-safe cleanser and flat storage, customers report 3–12 months of regular wear.</p>" } },
        "q5": { "type": "qa", "settings": { "question": "Can I wear them with glasses?",            "answer": "<p>Yes. Our Natural and Light makeup styles (Inbox, Minutes, Kickoff) are short enough to sit comfortably under glasses without touching the lenses.</p>" } },
        "q6": { "type": "qa", "settings": { "question": "Can I wear them with contact lenses?",     "answer": "<p>Absolutely. Hypoallergenic synthetic fibre, no glue near the eye, no irritation.</p>" } },
        "q7": { "type": "qa", "settings": { "question": "Do they work for monolids?",               "answer": "<p>Yes — and we built specific styles for monolids. Inbox and Minutes have flatter bands designed to sit on monolid and inner-double-lid eyes without lifting at the corners.</p>" } },
        "q8": { "type": "qa", "settings": { "question": "What's your return policy?",               "answer": "<p>14-day no-questions returns on unopened sets. If you've opened them and they don't fit your eye shape, message us — we'll match you with a different style on the house.</p>" } }
      },
      "block_order": ["q1", "q2", "q3", "q4", "q5", "q6", "q7", "q8"]
