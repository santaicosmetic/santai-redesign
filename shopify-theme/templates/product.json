      "blocks": {
        "rv1": { "type": "manual", "settings": { "title": "Honestly didn't believe it would work", "body": "First time trying magnetic lashes after years of mascara only. Was skeptical because every YouTube tutorial makes it look so easy and I'm bad at makeup. Took me about 4 tries to get them on properly on day 1 but by day 3 I was doing it in under a minute. They sit completely flat on my monolid.", "author": "Aisyah R.", "tag": "Monolid",          "rating": 5 } },
        "rv2": { "type": "manual", "settings": { "title": "Lighter than expected",                  "body": "These are seriously light. I keep forgetting I have them on.",                                                                                                                                                                                                                                                                "author": "Priya M.",  "tag": "Double lid",       "rating": 5 } },
        "rv3": { "type": "manual", "settings": { "title": "Took some practice but worth it",        "body": "Not as easy as the videos make it look. The magnets need to align properly or the band lifts at the corner. Once you figure out the angle though, it's genuinely a 30-second job.",                                                                                                                                          "author": "Lin T.",    "tag": "Inner double lid", "rating": 4 } }
      },
