<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#FFFFFF">
  <title>{{ page_title }}{% if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif %}{% if current_page != 1 %} &ndash; Page {{ current_page }}{% endif %}{% unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless %}</title>
  {% if page_description %}<meta name="description" content="{{ page_description | escape }}">{% endif %}

  <link rel="canonical" href="{{ canonical_url }}">

  {%- comment -%} Fonts: Newsreader (display) + Manrope (body) + JetBrains Mono — Direction C {%- endcomment -%}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,300..700;1,6..72,300..700&family=Manrope:wght@300..700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

  {{ 'santai.css' | asset_url | stylesheet_tag }}

  {%- comment -%}
    SANTAI_DATA + window.LASH_STYLES + window.ACCESSORIES — server-rendered from
    Shopify products so theme.js's search, compare, finder, and cart modules read
    live data instead of the prototype's hardcoded literal.
  {%- endcomment -%}
  <script>
    window.SANTAI_DATA = {
      productMap: {
        {%- for p in collections.all.products -%}
          "{{ p.id }}": {
            "handle": {{ p.handle | json }},
            "short_id": {{ p.metafields.santai.short_id.value | default: p.handle | json }},
            "category": {{ p.metafields.santai.category.value | default: '' | json }},
            "title": {{ p.title | json }},
            "variant_id": {{ p.selected_or_first_available_variant.id }}
          }{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      },
      idsByShortId: {
        {%- for p in collections.all.products -%}
          {%- assign sid = p.metafields.santai.short_id.value | default: p.handle -%}
          {{ sid | json }}: {{ p.selected_or_first_available_variant.id }}{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      }
    };

    {%- liquid
      assign lash_first = true
      assign acc_first = true
    -%}
    window.LASH_STYLES = {
      {%- for p in collections.all.products -%}
        {%- if p.metafields.santai.category.value == 'lash' -%}
          {%- if lash_first %}{%- assign lash_first = false -%}{%- else %},{%- endif -%}
          {%- assign sid = p.metafields.santai.short_id.value | default: p.handle -%}
          {%- assign eb_value = p.metafields.santai.eye_buckets.value -%}
          {%- if eb_value -%}
            {%- assign eye_type_str = eb_value | join: ' / ' | replace: 'monolid', 'Monolid' | replace: 'double-lid', 'Double lid' | replace: 'inner-double-lid', 'Inner double lid' -%}
          {%- else -%}
            {%- assign eye_type_str = 'All eye types' -%}
          {%- endif -%}
          {{ sid | json }}: {
            "id": {{ sid | json }},
            "name": {{ p.title | split: ' ' | first | json }},
            "group": {{ p.metafields.santai.group.value | default: '' | json }},
            "tagline": {{ p.metafields.santai.tagline.value | default: '' | json }},
            "image": {{ p.featured_image | image_url: width: 800 | json }},
            "card": {{ p.featured_image | image_url: width: 600 | json }},
            "drama": {{ p.metafields.santai.drama.value | default: 1 }},
            "eyeType": {{ eye_type_str | json }},
            "length": {{ p.metafields.santai.length.value | default: '' | json }},
            "curl": {{ p.metafields.santai.curl.value | default: '' | json }},
            "design": {{ p.metafields.santai.design.value | default: '' | json }},
            "price": {{ p.price | money | json }},
            "handle": {{ p.handle | json }},
            "url": {{ p.url | json }},
            {%- assign rvid = p.metafields.santai.real_video.value -%}
            "real_video": {% if rvid and rvid.sources and rvid.sources.size > 0 %}{{ rvid.sources.last.url | json }}{% else %}""{% endif %},
            "variant_id": {{ p.selected_or_first_available_variant.id }}
          }
        {%- endif -%}
      {%- endfor -%}
    };
    window.ACCESSORIES = {
      {%- for p in collections.all.products -%}
        {%- if p.metafields.santai.category.value == 'accessory' -%}
          {%- if acc_first %}{%- assign acc_first = false -%}{%- else %},{%- endif -%}
          {%- assign sid = p.metafields.santai.short_id.value | default: p.handle -%}
          {{ sid | json }}: {
            "id": {{ sid | json }},
            "name": {{ p.title | split: ':' | first | json }},
            "tagline": {{ p.metafields.santai.tagline.value | default: '' | json }},
            "image": {{ p.featured_image | image_url: width: 800 | json }},
            "price": {{ p.price | money | json }},
            "handle": {{ p.handle | json }},
            "url": {{ p.url | json }},
            "variant_id": {{ p.selected_or_first_available_variant.id }}
          }
        {%- endif -%}
      {%- endfor -%}
    };
  </script>

  {{ content_for_header }}
</head>
<body data-screen="{{ template | replace: '.', '-' }}">

  {%- section 'header' -%}

  {{ content_for_layout }}

  {%- section 'footer' -%}

  {%- render 'lash-finder' -%}
  {%- render 'cart-drawer' -%}
  {%- render 'newsletter-popup' -%}

  <div class="toast" data-toast role="status" aria-live="polite"></div>

  <script src="{{ 'theme.js' | asset_url }}" defer></script>
</body>
</html>
