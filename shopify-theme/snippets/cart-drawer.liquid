{%- comment -%}
  Cart drawer. Initial state is server-rendered (subtotal, item count, items),
  then theme.js takes over after add-to-cart / qty-change events via /cart.js Ajax.
  Gift-tier reconciliation, upsells, and per-wear math handled client-side.
{%- endcomment -%}

<div class="cart-overlay" data-cart-overlay data-cart-close></div>
<aside class="cart-drawer" data-cart-drawer aria-label="Cart">
  <div class="cart-drawer__head">
    <h2 class="cart-drawer__title">Your bag <span class="cart-drawer__title-count">(<span data-cart-count-inline>{{ cart.item_count }}</span>)</span></h2>
    <button type="button" class="cart-drawer__close" data-cart-close>Close</button>
  </div>

  <div class="cart-progress" data-cart-progress{% if cart.item_count == 0 %} style="display:none"{% endif %}>
    <div class="cart-progress__msg" data-progress-msg>Add <strong>2 lashes</strong> to unlock a free Foam Cleanser.</div>
    <div class="cart-progress__track">
      <div class="cart-progress__fill" data-progress-fill></div>
      <div class="cart-milestone" data-milestone="2">
        <span class="cart-milestone__dot"></span>
        <span class="cart-milestone__icon">◇</span>
        <span class="cart-milestone__label">Free Cleanser</span>
      </div>
      <div class="cart-milestone" data-milestone="3">
        <span class="cart-milestone__dot"></span>
        <span class="cart-milestone__icon">◈</span>
        <span class="cart-milestone__label">Free Curler</span>
      </div>
    </div>
  </div>

  <div class="cart-shipping-promise"><span class="cart-shipping-promise__icon">✓</span>Free shipping across Malaysia (West + East)</div>

  <div class="cart-empty" data-cart-empty{% if cart.item_count > 0 %} style="display:none"{% endif %}>
    <p>Your bag is empty.</p>
    <p class="small" style="margin-top:8px;color:var(--fg-muted)">Start with our bestseller, <a href="{{ routes.root_url }}products/pitch-magnetic-eyelashes" style="color:var(--accent)">Pitch</a>.</p>
  </div>

  <div class="cart-drawer__scroll">
    <div class="cart-items" data-cart-items></div>

    <div class="cart-upsells" data-cart-upsells{% if cart.item_count == 0 %} style="display:none"{% endif %}>
      <p class="cart-upsells__eyebrow">— You might also like</p>
      <div class="cart-upsells__row" data-upsells-row></div>
    </div>
  </div>

  <div class="cart-drawer__foot" data-cart-foot{% if cart.item_count == 0 %} style="display:none"{% endif %}>
    <div class="cart-discount">
      <input type="text" class="cart-discount__input" placeholder="Discount code" data-discount-input aria-label="Discount code">
      <button type="button" class="cart-discount__apply" data-discount-apply>Apply</button>
    </div>
    <div class="cart-savings" data-cart-savings style="display:none">
      <span>You saved</span>
      <span class="cart-savings__amount" data-cart-savings-amount>{{ 0 | money }}</span>
    </div>
    <div class="cart-total">
      <span class="cart-total__label">Subtotal</span>
      <span class="cart-total__amount tnum" data-cart-total>{{ cart.total_price | money }}</span>
    </div>
    <div class="cart-total__note">Shipping included. Taxes calculated at checkout.</div>
    <a class="btn btn-accent cart-drawer__checkout" href="/checkout">Checkout</a>
  </div>
</aside>
