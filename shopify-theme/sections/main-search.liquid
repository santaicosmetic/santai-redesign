<section class="section container search-page">
  <div class="section__head section__head--center">
    <div class="section__head-text">
      <div class="eyebrow">Search</div>
      <h2 class="display-l">
        {%- if search.performed -%}
          Results for <span class="display-italic">&ldquo;{{ search.terms | escape }}&rdquo;</span>
        {%- else -%}
          Search <span class="display-italic">Santai.</span>
        {%- endif -%}
      </h2>
    </div>
  </div>

  <form action="{{ routes.search_url }}" method="get" role="search" class="search-page__form" style="display:flex;gap:12px;max-width:560px;margin:0 auto var(--space-7);">
    <input type="hidden" name="type" value="product">
    <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="Search lashes, cleanser, monolid&hellip;" aria-label="Search" style="flex:1;padding:14px 16px;border:1px solid var(--line);background:var(--bg);font:400 16px/1.2 var(--font-body);">
    <button type="submit" class="btn btn-accent">Search</button>
  </form>

  {%- if search.performed -%}
    {%- if search.results_count > 0 -%}
      <div class="collection-grid collection-grid--3">
        {%- for item in search.results -%}
          {%- if item.object_type == 'product' -%}
            {% render 'product-card', product: item %}
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- else -%}
      <p style="text-align:center;color:var(--fg-muted)">
        No matches for &ldquo;{{ search.terms | escape }}&rdquo;. Try a different word, or
        <a href="{{ routes.all_products_collection_url }}" style="color:var(--accent)">browse the full collection &rarr;</a>
      </p>
    {%- endif -%}
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Search results",
  "settings": []
}
{% endschema %}
