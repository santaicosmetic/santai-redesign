<section class="pdp-videos container">
  <div class="pdp-videos__grid">
    <div class="pdp-videos__col">
      <div class="section__head section__head--center">
        <div class="section__head-text">
          <div class="eyebrow">{{ section.settings.eyebrow }}</div>
          <h2 class="display-m">{{ section.settings.heading_pre }}<span class="display-italic">{{ section.settings.heading_italic }}</span></h2>
        </div>
      </div>

      {%- liquid
        assign vid = section.settings.video
        assign poster = section.settings.poster
      -%}

      <div class="pdp-videos__video">
        {%- if vid != blank -%}
          <video
            src="{{ vid.sources[1].url | default: vid.sources[0].url }}"
            {% if poster != blank %}poster="{{ poster | image_url: width: 1200 }}"{% endif %}
            playsinline
            controls
            preload="metadata"
          ></video>
        {%- elsif poster != blank -%}
          <img src="{{ poster | image_url: width: 1200 }}" alt="" loading="lazy">
        {%- else -%}
          <div class="pdp-videos__placeholder" aria-hidden="true">Add a video in the theme editor</div>
        {%- endif -%}
      </div>

      {%- if section.settings.caption != blank -%}
        <p class="pdp-videos__caption">{{ section.settings.caption }}</p>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "PDP — Accessory video",
  "settings": [
    { "type": "text",         "id": "eyebrow",        "label": "Eyebrow" },
    { "type": "text",         "id": "heading_pre",    "label": "Heading start" },
    { "type": "text",         "id": "heading_italic", "label": "Heading italic" },
    { "type": "video",        "id": "video",          "label": "Video" },
    { "type": "image_picker", "id": "poster",         "label": "Poster image" },
    { "type": "text",         "id": "caption",        "label": "Caption below" }
  ],
  "presets": [{ "name": "PDP — Accessory video" }]
}
{% endschema %}
