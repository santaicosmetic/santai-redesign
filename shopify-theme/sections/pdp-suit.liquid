{%- liquid
  comment
    Per-eye-shape verdict for THIS product. Uses product.metafields.santai.eye_buckets
    to mark each eye shape as "Beautiful" (fits), "Wearable" (neutral) or "Try X" (doesn't fit, recommend a sibling).
    Sibling recommendation: pick first lash in same group that matches the missing bucket.
  endcomment

  assign mf = product.metafields.santai
  assign current_buckets = mf.eye_buckets.value
  assign all_shapes = 'monolid|double-lid|inner-double-lid' | split: '|'
-%}

<section class="section pdp-suit">
  <div class="container">
    <div class="section__head">
      <div class="section__head-text">
        <div class="eyebrow">{{ section.settings.eyebrow }}</div>
        <h2 class="display-l">{{ section.settings.heading_pre }}<span class="display-italic">{{ section.settings.heading_italic }}</span></h2>
      </div>
    </div>
    <div class="pdp-suit__grid">
      {%- for shape in all_shapes -%}
        {%- liquid
          case shape
            when 'monolid'
              assign label = 'Monolid'
              assign svg = 'monolid.svg'
            when 'double-lid'
              assign label = 'Double lid'
              assign svg = 'almond.svg'
            when 'inner-double-lid'
              assign label = 'Inner double lid'
              assign svg = 'hooded.svg'
          endcase

          assign fits = false
          if current_buckets contains shape
            assign fits = true
          endif

          assign rec_url = ''
          assign rec_title = ''
          assign rec_image = ''
          if fits
            assign rec_url = product.url
            assign rec_image = product.images[1] | default: product.featured_image
          else
            for sibling in collections['all'].products limit: 50
              if sibling.metafields.santai.category.value == 'lash' and sibling.id != product.id
                if sibling.metafields.santai.eye_buckets.value contains shape
                  assign rec_url = sibling.url
                  assign rec_title = sibling.title | split: ' ' | first
                  assign rec_image = sibling.images[1] | default: sibling.featured_image
                  break
                endif
              endif
            endfor
          endif
        -%}

        <a class="pdp-suit__cell{% unless fits %} pdp-suit__cell--alt{% endunless %}" href="{{ rec_url | default: product.url }}">
          <div class="pdp-suit__image{% if rec_image != blank %} pdp-suit__image--photo{% endif %}">
            {%- if rec_image != blank -%}
              <img src="{{ rec_image | image_url: width: 600 }}" alt="{% if fits %}{{ product.title }}{% else %}{{ rec_title }}{% endif %} on a {{ label }} eye">
            {%- else -%}
              <img src="{{ svg | asset_url }}" alt="{{ label }} eye shape">
            {%- endif -%}
          </div>
          <div class="pdp-suit__verdict">
            {%- if fits -%}
              <span class="eyebrow" style="color:var(--accent)">Beautiful</span>
            {%- elsif rec_title != blank -%}
              <span class="eyebrow">Try {{ rec_title }} &rarr;</span>
            {%- else -%}
              <span class="eyebrow">Not the best fit</span>
            {%- endif -%}
            <h3>{{ label }}</h3>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "PDP — Will this suit me",
  "settings": [
    { "type": "text", "id": "eyebrow",        "label": "Eyebrow",        "default": "Will this suit me?" },
    { "type": "text", "id": "heading_pre",    "label": "Heading start",  "default": "Three eye shapes. " },
    { "type": "text", "id": "heading_italic", "label": "Heading italic", "default": "Honest verdicts." }
  ],
  "presets": [{ "name": "PDP — Will this suit me" }]
}
{% endschema %}
